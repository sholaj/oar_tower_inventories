---
# Database Compliance Scanning Inventory
# Environment: DEVTEST | Region: NA
#
# Single env-level inventory. Technology groups (mssql_databases /
# oracle_databases / sybase_databases / postgres_databases) own
# PLATFORM-SPECIFIC per-BU child groups:
#
#     mssql_databases.children  -> db_<bu>_mssql
#     oracle_databases.children -> db_<bu>_oracle
#     sybase_databases.children -> db_<bu>_sybase
#
# A top-level db_<bu> group aggregates the per-platform subgroups so
# `--limit db_<bu>` still targets every host in a BU across platforms.
# BU-scoped vars (ssc_sn_environment, ssc_sn_region, ssc_sn_bu,
# inspec_delegate_host) live on the aggregator.
#
# WHY NOT a single `db_<bu>` group as a direct child of all three tech
# groups (as in the old layout): Ansible inventory YAML treats group
# names as global keys. Repeating `db_<bu>` under multiple tech groups
# merges every host list into one group that then becomes a child of
# every tech group, polluting `mssql_databases` with Oracle/Sybase
# hosts (and vice versa). Platform-specific subgroup names avoid the
# collision.
#
# Delegate hosts live in a separate top-level `delegate_hosts` group
# (Model B). Each BU's `inspec_delegate_host` names the runner it
# delegates to — different BUs may use different runners; shared
# runners are referenced by name from multiple BUs.
#
# Playbooks target the technology group, e.g.:
#   ansible-playbook -i DEVTEST_NA_Inv_InSpec_Database run_mssql_inspec.yml
#   ansible-playbook -i DEVTEST_NA_Inv_InSpec_Database run_oracle_inspec.yml --limit db_alpha
#     (--limit db_alpha hits the aggregator; combined with
#      hosts: oracle_databases it reduces to db_alpha_oracle hosts)
#
# BU directory names in this public mirror use NATO-phonetic
# placeholders (alpha/bravo/charlie/delta/echo). Real BU identifiers
# are not committed.

all:
  children:
    # ================================================================
    # Delegate hosts (InSpec execution targets, reached via SSH)
    # One per BU — different BUs may have different runners. Replace
    # with a shared runner by pointing multiple BUs at the same name.
    # ================================================================
    delegate_hosts:
      hosts:
        alpha-runner:
          ansible_host: "[DELEGATE_HOST_ALPHA]"
          ansible_user: ansible_svc
          ansible_connection: ssh
          ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"
        bravo-runner:
          ansible_host: "[DELEGATE_HOST_BRAVO]"
          ansible_user: ansible_svc
          ansible_connection: ssh
          ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"
        charlie-runner:
          ansible_host: "[DELEGATE_HOST_CHARLIE]"
          ansible_user: ansible_svc
          ansible_connection: ssh
          ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"
        delta-runner:
          ansible_host: "[DELEGATE_HOST_DELTA]"
          ansible_user: ansible_svc
          ansible_connection: ssh
          ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"
        echo-runner:
          ansible_host: "[DELEGATE_HOST_ECHO]"
          ansible_user: ansible_svc
          ansible_connection: ssh
          ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"

    # ================================================================
    # BU aggregator groups (top-level) — hold BU-wide vars, aggregate
    # the per-platform subgroups so `--limit db_<bu>` still works.
    # ================================================================
    db_alpha:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: alpha
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "alpha-runner"
      children:
        db_alpha_mssql:
        db_alpha_oracle:
        db_alpha_sybase:

    db_bravo:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: bravo
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "bravo-runner"
      children:
        db_bravo_mssql:
        db_bravo_oracle:

    db_charlie:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: charlie
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "charlie-runner"
      children:
        db_charlie_mssql:
        db_charlie_oracle:

    db_delta:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: delta
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "delta-runner"
      children:
        db_delta_mssql:
        db_delta_oracle:
        db_delta_sybase:

    db_echo:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: echo
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "echo-runner"
      children:
        db_echo_mssql:
        db_echo_sybase:

    # ================================================================
    # MSSQL Servers (scanned at server level)
    # ================================================================
    mssql_databases:
      children:
        db_alpha_mssql:
          hosts:
            ALPHA_DBSERVER01_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2019"
              mssql_username: nist_scan_user
              mssql_database: master
            ALPHA_DBSERVER02_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2022"
              mssql_username: nist_scan_user
              mssql_database: master

        db_bravo_mssql:
          hosts:
            BRAVO_DBSERVER01_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2019"
              mssql_username: nist_scan_user
              mssql_database: master

        db_charlie_mssql:
          hosts:
            CHARLIE_DBSERVER01_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2022"
              mssql_username: nist_scan_user
              mssql_database: master

        db_delta_mssql:
          hosts:
            DELTA_DBSERVER01_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2019"
              mssql_username: nist_scan_user
              mssql_database: master

        db_echo_mssql:
          hosts:
            ECHO_DBSERVER01_1433:
              mssql_server: "[DB_SERVER].example.internal"
              mssql_port: 1433
              mssql_version: "2017"
              mssql_username: nist_scan_user
              mssql_database: master

    # ================================================================
    # Oracle Databases (scanned per database/service)
    # ================================================================
    oracle_databases:
      children:
        db_alpha_oracle:
          hosts:
            ALPHA_ORADB01_1521:
              oracle_server: "[DB_SERVER].example.internal"
              oracle_port: 1521
              oracle_service: ORCL
              oracle_version: "19"
              oracle_username: nist_scan_user

        db_bravo_oracle:
          hosts:
            BRAVO_ORADB01_1521:
              oracle_server: "[DB_SERVER].example.internal"
              oracle_port: 1521
              oracle_service: ORCL
              oracle_version: "19"
              oracle_username: nist_scan_user

        db_charlie_oracle:
          hosts:
            CHARLIE_ORADB01_1521:
              oracle_server: "[DB_SERVER].example.internal"
              oracle_port: 1521
              oracle_service: ORCL
              oracle_version: "12"
              oracle_username: nist_scan_user

        db_delta_oracle:
          hosts:
            DELTA_ORADB01_1521:
              oracle_server: "[DB_SERVER].example.internal"
              oracle_port: 1521
              oracle_service: ORCL
              oracle_version: "19"
              oracle_username: nist_scan_user

    # ================================================================
    # Sybase Databases (scanned per database)
    # ================================================================
    sybase_databases:
      children:
        db_alpha_sybase:
          hosts:
            ALPHA_SYBDB01_5000:
              sybase_server: "[DB_SERVER].example.internal"
              sybase_port: 5000
              sybase_service: SYBDB01
              sybase_version: "16"
              sybase_username: nist_scan_user
              sybase_database: master

        db_delta_sybase:
          hosts:
            DELTA_SYBDB01_5000:
              sybase_server: "[DB_SERVER].example.internal"
              sybase_port: 5000
              sybase_service: SYBDB01
              sybase_version: "16"
              sybase_username: nist_scan_user
              sybase_database: master

        db_echo_sybase:
          hosts:
            ECHO_SYBDB01_5000:
              sybase_server: "[DB_SERVER].example.internal"
              sybase_port: 5000
              sybase_service: SYBDB01
              sybase_version: "16"
              sybase_username: nist_scan_user
              sybase_database: master
