---
# CORP Business Unit - Database Compliance Scanning Inventory
# Environment: DEVTEST | Region: NA | BU: CORP
#
# Usage:
#   ansible-playbook -i CORP/CORP_DEVTEST_NA_Inv_InSpec_Database run_compliance_scans.yml

all:
  children:
    db_corp:
      vars:
        ssc_sn_environment: test
        ssc_sn_region: na
        ssc_sn_bu: corp
        exec_timeout: 600
        ansible_connection: local
        inspec_delegate_host: "[DELEGATE_HOST]"

      hosts:
        # MSSQL Servers
        DBSERVER01_1433:
          database_platform: mssql
          mssql_server: "[DB_SERVER].example.internal"
          mssql_port: 1433
          mssql_version: "2019"
          mssql_username: nist_scan_user
          mssql_database: master

        DBSERVER02_1433:
          database_platform: mssql
          mssql_server: "[DB_SERVER].example.internal"
          mssql_port: 1433
          mssql_version: "2022"
          mssql_username: nist_scan_user
          mssql_database: master

        # Oracle Databases
        ORADB01_1521:
          database_platform: oracle
          oracle_server: "[DB_SERVER].example.internal"
          oracle_port: 1521
          oracle_service: ORCL
          oracle_version: "19"
          oracle_username: nist_scan_user

        # Sybase Databases
        SYBDB01_5000:
          database_platform: sybase
          sybase_server: "[DB_SERVER].example.internal"
          sybase_port: 5000
          sybase_service: SYBDB01
          sybase_version: "16"
          sybase_username: nist_scan_user
          sybase_database: master
